{
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md",
      "CLAUDE.md"
    ]
  },
  "mcpServers": {
    "ruflo": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "adaptive",
        "CLAUDE_FLOW_MAX_AGENTS": "50",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "timeout": 30000,
      "trust": false
    },
    "ruv-swarm": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "ruv-swarm",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false"
      },
      "timeout": 30000,
      "trust": false
    }
  }
}

