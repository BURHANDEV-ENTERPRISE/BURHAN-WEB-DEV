{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "pre-bash"],
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "pre-edit"],
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "post-edit"],
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "post-bash"],
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "route"],
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "session-restore"],
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/auto-memory-hook.mjs", "import"],
            "timeout": 8000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "session-end"],
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/auto-memory-hook.mjs", "sync"],
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "compact-manual"]
          },
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "session-end"],
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "compact-auto"]
          },
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "session-end"],
            "timeout": 6000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "status"],
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "post-task"],
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["bin/mop-run.mjs", ".claude/helpers/hook-handler.cjs", "notify"],
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"const fs=require('fs'),p=require('path');const d=process.env.CLAUDE_PROJECT_DIR||'.';const f=p.join(d,'.claude/helpers/statusline.cjs');if(fs.existsSync(f))require(f);\""
  },
  "permissions": {
    "allow": [
      "Bash(node .MOP/scripts/*)",
      "Bash(node .claude/helpers/*)",
      "Bash(node bin/*)",
      "mcp__mop-flow__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "MOP_FLOW_BRAND": "MOP Flow",
    "MOP_FLOW_CANONICAL": "true",
    "MOP_FLOW_PROVIDER_PARITY": "true"
  },
  "mopFlow": {
    "brand": "MOP Flow",
    "canonicalMcpServer": "mop-flow",
    "portableSkillDir": ".agents/skills",
    "runtimeNativeSkillDir": ".claude/skills",
    "manifestCommand": "node .MOP/scripts/mop-flow.mjs manifest refresh",
    "statusCommand": "node .MOP/scripts/mop-flow.mjs status --json",
    "providerParity": {
      "enabled": true,
      "providers": [
        "claude",
        "codex",
        "gemini",
        "antigravity"
      ]
    }
  }
}
